# media you drop in / results you generate — never committed
input/*
output/*
!input/.gitkeep
!output/.gitkeep

# python
.venv/
__pycache__/
*.pyc

# ensemble workdir, media, and logs
.subtitle-ensemble/
*.log
*.mp4
*.mkv
*.webm
*.mov
*.avi
*.m4v
*.ts
*.flv

# scratch audio
*.wav

# test/tool caches
.pytest_cache/
.coverage

# macOS
.DS_Store

# claude code agent worktrees / local state
.claude/worktrees/
